rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Un témoin anonyme doit pouvoir signaler sans compte : création ouverte.
    // En revanche, lire ou modifier des signalements existants (position des
    // victimes, changement de statut...) est réservé aux comptes pompiers
    // authentifiés (Firebase Auth, email/mot de passe — voir js/auth.js).
    match /reports/{reportId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
